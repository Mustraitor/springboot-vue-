@startuml
' 设置布局方向
top to bottom direction

' ================= Controller 层 =================
class SysRoleController {
  + optionSelect(): RestResult
  + add(role: SysRoleVO): RestResult
  + getInfo(roleId: Long): RestResult
  + remove(roleIds: Long[]): RestResult
  + list(role: SysRoleVO, pageable: Pageable): TableDataInfo
  + edit(role: SysRoleVO): RestResult
  + changeStatus(role: SysRoleVO): RestResult
}

' ================= Service 接口 =================
interface SysRoleService {
  + checkRoleKeyUnique(role: SysRoleVO): String
  + updateRoleStatus(role: SysRoleVO): int
  + selectRolePermissionByUserId(userId: Long): Set<String>
  + deleteRoleByIds(roleIds: Long[]): int
  + selectRoleById(roleId: Long): SysRole
  + insertRole(role: SysRoleVO): int
  + checkRoleNameUnique(role: SysRoleVO): String
  + updateRole(role: SysRoleVO): int
  + checkRoleAllowed(role: SysRoleVO): void
  + countUserRoleByRoleId(roleId: Long): int
  + selectRoleList(role: SysRoleVO, pageable: Pageable): TableDataInfo
  + selectRoleAll(): List<SysRole>
  + selectRoleListByUserId(userId: Long): List<Long>
}

' ================= Service 实现类 =================
class SysRoleServiceImpl {
  + checkRoleKeyUnique(role: SysRoleVO): String
  + updateRoleStatus(role: SysRoleVO): int
  + selectRolePermissionByUserId(userId: Long): Set<String>
  + deleteRoleByIds(roleIds: Long[]): int
  + selectRoleById(roleId: Long): SysRole
  + insertRole(role: SysRoleVO): int
  + checkRoleNameUnique(role: SysRoleVO): String
  + updateRole(role: SysRoleVO): int
  + checkRoleAllowed(role: SysRoleVO): void
  + countUserRoleByRoleId(roleId: Long): int
  + selectRoleList(role: SysRoleVO, pageable: Pageable): TableDataInfo
  + selectRoleAll(): List<SysRole>
  + selectRoleListByUserId(userId: Long): List<Long>
}

interface JpaRepository<T, ID>

' ================= Repository 层 =================
interface SysRoleRepository {
  + deleteRoleByIds(Long[]): int
  + deleteRoleMenuByRoleId(Long): int
  + selectRoleIdsByUserId(Long): List<Long>
  + selectRoleByUserId(Long): List<SysRole>
  + countUserRoleByRoleId(Long): int
}
SysRoleRepository --|> JpaRepository

' ================= Model / VO =================
class SysRole {
    - roleId: Long
    - roleName: String
    - roleKey: String
    - status: String
    - delFlag: String
    - createBy: String
    - createTime: Instant
    - updateBy: String
    - updateTime: Instant
    - remark: String
}

class SysRoleVO {
    - roleId: Long
    - roleName: String
    - roleKey: String
    - status: String
    - menuIds: Long[]
}

' ================= 类关系 =================
SysRoleController --> SysRoleService : 调用
SysRoleService <|.. SysRoleServiceImpl : 实现
SysRoleServiceImpl --> SysRoleRepository : 调用
SysRoleRepository --> SysRole : 操作实体
SysRoleController --> SysRoleVO : 接收参数
SysRoleServiceImpl --> SysRoleVO : 使用

@enduml
